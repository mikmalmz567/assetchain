# AssetChain API Environment Variables

# App
NODE_ENV=development
PORT=3001

# Database (lokal - ganti kalau pakai cloud)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assetchain_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=dev_secret_ganti_di_production_nanti
JWT_EXPIRES_IN=7d

# Blockchain
RPC_URL=https://rpc-mumbai.maticvigil.com
CHAIN_ID=80001

# IPFS (Pinata)
PINATA_API_KEY=ISI_NANTI
PINATA_SECRET_KEY=ISI_NANTI

# Payment
MIDTRANS_SERVER_KEY=ISI_NANTI
MIDTRANS_CLIENT_KEY=ISI_NANTI
MIDTRANS_IS_PRODUCTION=false

# KYC
VERIHUBS_API_KEY=ISI_NANTI

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:3000
