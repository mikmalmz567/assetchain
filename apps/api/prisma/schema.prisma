// This is your Prisma schema file for AssetChain

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum Role {
  UMKM
  INVESTOR
  ADMIN
  VERIFIKATOR
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum AssetStatus {
  DRAFT
  REVIEW
  APPROVED
  MINTED
  FULLY_FUNDED
  ACTIVE
  COMPLETED
  REJECTED
}

enum AssetType {
  INVOICE
  INVENTORY
  PROPERTY
  RECEIVABLE
  OTHER
}

enum TransactionType {
  PURCHASE
  YIELD_CLAIM
  SECONDARY_SALE
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

// ============ MODELS ============

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  walletAddress  String?   @unique
  passwordHash   String?
  role           Role      @default(INVESTOR)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  umkmProfile    UmkmProfile?
  kycDocument    KycDocument?
  investments    Investment[]
  transactions   Transaction[]

  @@map("users")
}

model UmkmProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  namaUsaha     String
  jenisUsaha    String
  alamat        String
  kota          String
  provinsi      String
  npwp          String?
  nib           String?   // Nomor Induk Berusaha
  phoneNumber   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation(fields: [userId], references: [id])
  assets        Asset[]

  @@map("umkm_profiles")
}

model KycDocument {
  id            String    @id @default(cuid())
  userId        String    @unique
  nik           String
  selfieUrl     String?
  ktpUrl        String?
  status        KycStatus @default(PENDING)
  reviewNote    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          User      @relation(fields: [userId], references: [id])

  @@map("kyc_documents")
}

model Asset {
  id              String      @id @default(cuid())
  umkmProfileId   String
  namaAset        String
  deskripsi       String
  tipeAset        AssetType
  nilaiAset       BigInt      // Nilai dalam IDR (satuan rupiah)
  targetDana      BigInt      // Dana yang dicari
  yieldRate       Float       // Persentase per tahun (e.g. 12.5)
  tenorDays       Int         // Tenor dalam hari
  pricePerToken   BigInt      // Harga per token (IDR)
  totalTokens     Int         // Jumlah total token
  soldTokens      Int         @default(0)
  status          AssetStatus @default(DRAFT)

  // Blockchain data
  contractAddress String?
  tokenId         String?
  ipfsHash        String?     // IPFS hash untuk metadata

  // Dates
  approvedAt      DateTime?
  mintedAt        DateTime?
  fundingDeadline DateTime?
  maturityDate    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  umkmProfile     UmkmProfile   @relation(fields: [umkmProfileId], references: [id])
  documents       AssetDocument[]
  investments     Investment[]
  yieldRecords    YieldRecord[]

  @@map("assets")
}

model AssetDocument {
  id          String   @id @default(cuid())
  assetId     String
  docType     String   // invoice, sertifikat, foto, dsb
  fileName    String
  ipfsHash    String
  url         String
  createdAt   DateTime @default(now())

  // Relations
  asset       Asset    @relation(fields: [assetId], references: [id])

  @@map("asset_documents")
}

model Investment {
  id              String   @id @default(cuid())
  investorId      String
  assetId         String
  tokenAmount     Int
  purchasePrice   BigInt   // Total harga bayar (IDR)
  status          String   @default("ACTIVE")
  purchasedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  investor        User     @relation(fields: [investorId], references: [id])
  asset           Asset    @relation(fields: [assetId], references: [id])
  transactions    Transaction[]

  @@map("investments")
}

model YieldRecord {
  id              String   @id @default(cuid())
  assetId         String
  period          String   // e.g. "2024-01", "2024-02"
  amountPerToken  BigInt   // IDR per token
  totalAmount     BigInt   // Total yang didistribusikan
  distributedAt   DateTime @default(now())
  txHash          String?  // On-chain transaction hash

  // Relations
  asset           Asset    @relation(fields: [assetId], references: [id])

  @@map("yield_records")
}

model Transaction {
  id            String            @id @default(cuid())
  userId        String
  investmentId  String?
  type          TransactionType
  amount        BigInt
  status        TransactionStatus @default(PENDING)
  txHash        String?
  paymentRef    String?           // Midtrans/Xendit reference
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  user          User              @relation(fields: [userId], references: [id])
  investment    Investment?       @relation(fields: [investmentId], references: [id])

  @@map("transactions")
}
